{
  "$schema": "https://schemas.tokens.studio/latest/tokens-schema.json",
  "$description": "Cabeceira Design System — W3C Design Tokens. Importable into Tokens Studio for Figma, Style Dictionary, or any spec-compliant pipeline.",
  "color": {
    "brand": {
      "primary": {
        "$value": "#013220",
        "$type": "color",
        "$description": "Deep forest green — brand anchor. Headings, primary buttons, dark blocks."
      },
      "accent": {
        "$value": "#F89D93",
        "$type": "color",
        "$description": "Warm coral / café cereja. Eyebrows, pills, CTAs on dark."
      }
    },
    "background": {
      "light": { "$value": "#FAFAF8", "$type": "color", "$description": "Bone / ivory page bg, light mode." },
      "dark":  { "$value": "#0A120E", "$type": "color", "$description": "Near-black green-tinged page bg, dark mode." }
    },
    "tint": {
      "primary-05": { "$value": "rgba(1, 50, 32, 0.05)", "$type": "color" },
      "primary-10": { "$value": "rgba(1, 50, 32, 0.10)", "$type": "color" },
      "primary-20": { "$value": "rgba(1, 50, 32, 0.20)", "$type": "color" },
      "accent-10":  { "$value": "rgba(248, 157, 147, 0.10)", "$type": "color" },
      "accent-20":  { "$value": "rgba(248, 157, 147, 0.20)", "$type": "color" }
    },
    "slate": {
      "50":  { "$value": "#f8fafc", "$type": "color" },
      "100": { "$value": "#f1f5f9", "$type": "color" },
      "200": { "$value": "#e2e8f0", "$type": "color" },
      "300": { "$value": "#cbd5e1", "$type": "color" },
      "400": { "$value": "#94a3b8", "$type": "color" },
      "500": { "$value": "#64748b", "$type": "color" },
      "600": { "$value": "#475569", "$type": "color" },
      "700": { "$value": "#334155", "$type": "color" },
      "800": { "$value": "#1e293b", "$type": "color" },
      "900": { "$value": "#0f172a", "$type": "color" }
    }
  },
  "font": {
    "family": {
      "sans":    { "$value": "Plus Jakarta Sans, ui-sans-serif, system-ui, sans-serif", "$type": "fontFamily" },
      "display": { "$value": "Plus Jakarta Sans, ui-sans-serif, system-ui, sans-serif", "$type": "fontFamily" }
    },
    "weight": {
      "light":     { "$value": 300, "$type": "fontWeight" },
      "regular":   { "$value": 400, "$type": "fontWeight" },
      "medium":    { "$value": 500, "$type": "fontWeight" },
      "semibold":  { "$value": 600, "$type": "fontWeight" },
      "bold":      { "$value": 700, "$type": "fontWeight" },
      "extrabold": { "$value": 800, "$type": "fontWeight" }
    },
    "size": {
      "xs":   { "$value": "12px", "$type": "dimension", "$description": "Eyebrow uppercase" },
      "sm":   { "$value": "14px", "$type": "dimension", "$description": "Caption, badge" },
      "base": { "$value": "16px", "$type": "dimension", "$description": "Body" },
      "lg":   { "$value": "18px", "$type": "dimension", "$description": "Lead paragraph" },
      "xl":   { "$value": "20px", "$type": "dimension" },
      "2xl":  { "$value": "24px", "$type": "dimension", "$description": "H3 / cards" },
      "3xl":  { "$value": "30px", "$type": "dimension", "$description": "H2 mobile" },
      "4xl":  { "$value": "36px", "$type": "dimension", "$description": "H2 default" },
      "5xl":  { "$value": "48px", "$type": "dimension", "$description": "Big H2 / hero mobile" },
      "6xl":  { "$value": "60px", "$type": "dimension", "$description": "About H2" },
      "7xl":  { "$value": "72px", "$type": "dimension", "$description": "Hero H1 desktop" }
    },
    "lineHeight": {
      "tight":   { "$value": 1.1,   "$type": "number" },
      "snug":    { "$value": 1.25,  "$type": "number" },
      "normal":  { "$value": 1.5,   "$type": "number" },
      "relaxed": { "$value": 1.625, "$type": "number" }
    },
    "tracking": {
      "tight":   { "$value": "-0.025em", "$type": "dimension" },
      "normal":  { "$value": "0",        "$type": "dimension" },
      "wider":   { "$value": "0.05em",   "$type": "dimension" },
      "widest":  { "$value": "0.1em",    "$type": "dimension" }
    }
  },
  "radius": {
    "sm":   { "$value": "6px",   "$type": "dimension" },
    "base": { "$value": "12px",  "$type": "dimension", "$description": "Tailwind default override" },
    "lg":   { "$value": "16px",  "$type": "dimension" },
    "xl":   { "$value": "20px",  "$type": "dimension", "$description": "Dropdown menus" },
    "2xl":  { "$value": "24px",  "$type": "dimension", "$description": "Buttons, small cards" },
    "3xl":  { "$value": "32px",  "$type": "dimension", "$description": "Testimonial cards" },
    "4xl":  { "$value": "40px",  "$type": "dimension", "$description": "Service cards" },
    "5xl":  { "$value": "48px",  "$type": "dimension", "$description": "Hero frame, CTA block" },
    "6xl":  { "$value": "64px",  "$type": "dimension", "$description": "Vision frame" },
    "full": { "$value": "9999px","$type": "dimension" }
  },
  "shadow": {
    "sm": {
      "$type": "shadow",
      "$value": { "color": "rgba(0,0,0,0.05)", "offsetX": "0", "offsetY": "1px", "blur": "2px", "spread": "0" }
    },
    "md": {
      "$type": "shadow",
      "$value": [
        { "color": "rgba(0,0,0,0.10)", "offsetX": "0", "offsetY": "4px", "blur": "6px", "spread": "-1px" },
        { "color": "rgba(0,0,0,0.10)", "offsetX": "0", "offsetY": "2px", "blur": "4px", "spread": "-2px" }
      ]
    },
    "lg": {
      "$type": "shadow",
      "$value": [
        { "color": "rgba(0,0,0,0.10)", "offsetX": "0", "offsetY": "10px", "blur": "15px", "spread": "-3px" },
        { "color": "rgba(0,0,0,0.10)", "offsetX": "0", "offsetY": "4px", "blur": "6px", "spread": "-4px" }
      ]
    },
    "xl": {
      "$type": "shadow",
      "$value": [
        { "color": "rgba(0,0,0,0.10)", "offsetX": "0", "offsetY": "20px", "blur": "25px", "spread": "-5px" },
        { "color": "rgba(0,0,0,0.10)", "offsetX": "0", "offsetY": "8px", "blur": "10px", "spread": "-6px" }
      ]
    },
    "2xl": {
      "$type": "shadow",
      "$value": { "color": "rgba(0,0,0,0.25)", "offsetX": "0", "offsetY": "25px", "blur": "50px", "spread": "-12px" }
    },
    "primary-20": {
      "$type": "shadow",
      "$description": "Brand-tinted CTA lift",
      "$value": { "color": "rgba(1,50,32,0.20)", "offsetX": "0", "offsetY": "20px", "blur": "30px", "spread": "-10px" }
    },
    "accent-10": {
      "$type": "shadow",
      "$value": { "color": "rgba(248,157,147,0.10)", "offsetX": "0", "offsetY": "20px", "blur": "30px", "spread": "-10px" }
    }
  },
  "spacing": {
    "1":  { "$value": "4px",  "$type": "dimension" },
    "2":  { "$value": "8px",  "$type": "dimension" },
    "3":  { "$value": "12px", "$type": "dimension" },
    "4":  { "$value": "16px", "$type": "dimension" },
    "6":  { "$value": "24px", "$type": "dimension" },
    "8":  { "$value": "32px", "$type": "dimension" },
    "10": { "$value": "40px", "$type": "dimension" },
    "12": { "$value": "48px", "$type": "dimension" },
    "16": { "$value": "64px", "$type": "dimension" },
    "20": { "$value": "80px", "$type": "dimension" },
    "24": { "$value": "96px", "$type": "dimension", "$description": "Standard section vertical padding" }
  }
}
